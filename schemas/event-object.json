{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://geo-market-watch/schemas/event-object.json",
  "title": "Geo Market Watch Event Object",
  "description": "Normalized geopolitical or macro event input object for the Geo Market Watch pipeline.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "created_at",
    "event_timestamp",
    "title",
    "summary",
    "event_type",
    "status",
    "source_tier",
    "confidence_level",
    "geographies",
    "actors",
    "sources"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "description": "Globally unique event identifier.",
      "pattern": "^gmw-[0-9]{4}-[0-9]{4,}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when this event object was created by the system."
    },
    "event_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Best-known timestamp for when the underlying event occurred."
    },
    "title": {
      "type": "string",
      "minLength": 5,
      "maxLength": 300,
      "description": "Short event title."
    },
    "summary": {
      "type": "string",
      "minLength": 20,
      "maxLength": 4000,
      "description": "Concise event summary."
    },
    "event_type": {
      "type": "string",
      "enum": [
        "military_escalation",
        "sanctions",
        "export_control",
        "trade_policy",
        "shipping_disruption",
        "port_disruption",
        "pipeline_disruption",
        "commodity_supply_disruption",
        "infrastructure_damage",
        "labor_strike",
        "regulatory_change",
        "election_political_risk",
        "civil_unrest",
        "natural_disaster",
        "cyber_incident",
        "industrial_accident",
        "diplomatic_breakthrough",
        "ceasefire_negotiation",
        "other"
      ],
      "description": "Primary event category."
    },
    "status": {
      "type": "string",
      "enum": [
        "confirmed",
        "partially_confirmed",
        "unconfirmed",
        "disputed",
        "resolved"
      ],
      "description": "Current verification state of the event."
    },
    "source_tier": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4,
      "description": "Overall source quality tier. 1 = highest quality."
    },
    "confidence_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "description": "System confidence in the event facts as currently stated."
    },
    "fog_of_war": {
      "type": "boolean",
      "default": false,
      "description": "Whether the event is currently in a high-uncertainty, contradictory information environment."
    },
    "urgency": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ],
      "description": "Operational urgency for analysis or monitoring."
    },
    "market_relevance_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Normalized score for likely market impact."
    },
    "escalation_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Normalized score for whether the event should be escalated into deeper analysis."
    },
    "geographies": {
      "type": "array",
      "description": "Relevant countries, regions, maritime chokepoints, ports, or routes.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/geography"
      }
    },
    "actors": {
      "type": "array",
      "description": "Relevant state actors, companies, organizations, or non-state actors.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/actor"
      }
    },
    "commodities": {
      "type": "array",
      "description": "Relevant commodities or materials exposed to the event.",
      "items": {
        "type": "string",
        "minLength": 2,
        "maxLength": 100
      },
      "uniqueItems": true
    },
    "infrastructure_nodes": {
      "type": "array",
      "description": "Physical infrastructure nodes involved in the event.",
      "items": {
        "$ref": "#/$defs/infrastructureNode"
      }
    },
    "market_domains": {
      "type": "array",
      "description": "High-level market domains impacted by the event.",
      "items": {
        "type": "string",
        "enum": [
          "energy",
          "metals_mining",
          "shipping",
          "ports_logistics",
          "semiconductors",
          "defense",
          "agriculture",
          "chemicals",
          "utilities",
          "industrials",
          "consumer",
          "fx_rates",
          "rates_credit",
          "equities",
          "etfs",
          "other"
        ]
      },
      "uniqueItems": true
    },
    "sources": {
      "type": "array",
      "description": "Underlying sources used to construct the event object.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source"
      }
    },
    "contradictions": {
      "type": "array",
      "description": "List of major factual contradictions between sources.",
      "items": {
        "$ref": "#/$defs/contradiction"
      }
    },
    "tags": {
      "type": "array",
      "description": "Optional freeform tags for routing, indexing, or filtering.",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 50
      },
      "uniqueItems": true
    },
    "raw_input_refs": {
      "type": "array",
      "description": "References to raw user input, feed URLs, document IDs, or internal object IDs.",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "geography": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "type": {
          "type": "string",
          "enum": [
            "country",
            "region",
            "city",
            "port",
            "strait",
            "canal",
            "sea_route",
            "mine",
            "pipeline",
            "refinery",
            "industrial_zone",
            "other"
          ]
        },
        "iso_code": {
          "type": "string",
          "minLength": 2,
          "maxLength": 10
        }
      }
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "actor_type"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 2,
          "maxLength": 200
        },
        "actor_type": {
          "type": "string",
          "enum": [
            "state",
            "company",
            "militia",
            "international_organization",
            "regulator",
            "port_operator",
            "shipping_company",
            "commodity_producer",
            "union",
            "other"
          ]
        },
        "country": {
          "type": "string",
          "minLength": 2,
          "maxLength": 100
        }
      }
    },
    "infrastructureNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "node_type"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 2,
          "maxLength": 200
        },
        "node_type": {
          "type": "string",
          "enum": [
            "port",
            "terminal",
            "pipeline",
            "mine",
            "rail",
            "refinery",
            "power_plant",
            "smelter",
            "industrial_park",
            "shipping_lane",
            "other"
          ]
        },
        "country": {
          "type": "string",
          "minLength": 2,
          "maxLength": 100
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "publisher", "source_type", "tier", "url", "published_at"],
      "properties": {
        "source_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "publisher": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "source_type": {
          "type": "string",
          "enum": [
            "newswire",
            "newspaper",
            "government",
            "company_statement",
            "exchange_filing",
            "social_media",
            "ngo",
            "industry_report",
            "satellite_or_osint",
            "other"
          ]
        },
        "tier": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "published_at": {
          "type": "string",
          "format": "date-time"
        },
        "headline": {
          "type": "string",
          "maxLength": 500
        }
      }
    },
    "contradiction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "description"],
      "properties": {
        "field": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "description": {
          "type": "string",
          "minLength": 5,
          "maxLength": 1000
        },
        "source_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "uniqueItems": true
        }
      }
    }
  }
}
