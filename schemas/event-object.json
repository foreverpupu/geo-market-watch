{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://geo-market-watch/schemas/event-object.json",
  "title": "Geo Market Watch Event Object",
  "description": "Normalized geopolitical or macro event input object for the Geo Market Watch pipeline.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "created_at",
    "event_timestamp",
    "title",
    "summary",
    "event_type",
    "status",
    "source_tier",
    "confidence_level",
    "geographies",
    "actors",
    "sources"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "description": "Globally unique event identifier.",
      "pattern": "^gmw-[0-9]{4}-[0-9]{4,}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when this event object was created by the system."
    },
    "event_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Best-known timestamp for when the underlying event occurred."
    },
    "title": {
      "type": "string",
      "minLength": 5,
      "maxLength": 300,
      "description": "Short event title."
    },
    "summary": {
      "type": "string",
      "minLength": 20,
      "maxLength": 4000,
      "description": "Concise event summary."
    },
    "event_type": {
      "type": "string",
      "enum": [
        "military_escalation",
        "sanctions",
        "export_control",
        "trade_policy",
        "shipping_disruption",
        "port_disruption",
        "pipeline_disruption",
        "commodity_supply_disruption",
        "infrastructure_damage",
        "labor_strike",
        "regulatory_change",
        "election_political_risk",
        "civil_unrest",
        "natural_disaster",
        "cyber_incident",
        "industrial_accident",
        "diplomatic_breakthrough",
        "ceasefire_negotiation",
        "other"
      ],
      "description": "Primary event category."
    },
    "status": {
      "type": "string",
      "enum": [
        "confirmed",
        "partially_confirmed",
        "unconfirmed",
        "disputed",
        "resolved"
      ],
      "description": "Current verification state of the event."
    },
    "source_tier": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4,
      "description": "Overall source quality tier. 1 = highest quality."
    },
    "confidence_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "description": "System confidence in the event facts as currently stated."
    },
    "fog_of_war": {
      "type": "boolean",
      "default": false,
      "description": "Whether the event is currently in a high-uncertainty, contradictory information environment."
    },
    "urgency": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ],
      "description": "Operational urgency for analysis or monitoring."
    },
    "market_relevance_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Normalized score for likely market impact."
    },
    "escalation_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Normalized score for whether the event should be escalated into deeper analysis."
    },
    "geographies": {
      "type": "array",
      "description": "Relevant countries, regions, maritime chokepoints, ports, or routes.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/geography"
      }
    },
    "actors": {
      "type": "array",
      "description": "Relevant state actors, companies, organizations, or non-state actors.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/actor"
      }
    },
    "commodities": {
      "type": "array",
      "description": "Relevant commodities or materials exposed to the event.",
      "items": {
        "type": "string",
        "minLength": 2,
        "maxLength": 100
      },
      "uniqueItems": true
    },
    "infrastructure_nodes": {
      "type": "array",
      "description": "Physical infrastructure nodes involved in the event.",
      "items": {
        "$ref": "#/$defs/infrastructureNode"
      }
    },
    "market_domains": {
      "type": "array",
      "description": "High-level market domains impacted by the event.",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "geography": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["country", "region", "chokepoint", "port", "route"]
        },
        "coordinates": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" }
          }
        }
      }
    },
    "actor": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["state", "corporate", "organization", "non_state_actor"]
        },
        "role": {
          "type": "string",
          "enum": ["aggressor", "target", "mediator", "observer", "beneficiary"]
        }
      }
    },
    "infrastructureNode": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["port", "pipeline", "terminal", "refinery", "mine", "factory", "route"]
        },
        "location": { "type": "string" }
      }
    }
  }
}
