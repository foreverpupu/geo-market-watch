{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/foreverpupu/geo-market-watch/schemas/event-object.json",
  "title": "Geo Market Watch Event Object",
  "description": "Standardized representation of a geopolitical event for analysis",
  "type": "object",
  "required": ["event_id", "timestamp", "event_type", "source", "confidence"],
  "properties": {
    "event_id": {
      "type": "string",
      "description": "Unique identifier for the event",
      "pattern": "^[a-z0-9_-]+$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the event occurred or was reported"
    },
    "location": {
      "type": "object",
      "description": "Geographic information about the event",
      "properties": {
        "country": { "type": "string" },
        "region": { "type": "string" },
        "coordinates": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" }
          }
        }
      }
    },
    "actors": {
      "type": "array",
      "description": "Entities involved in the event",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["state", "organization", "individual", "military", "corporate"]
          },
          "role": {
            "type": "string",
            "enum": ["aggressor", "target", "mediator", "observer"]
          }
        }
      }
    },
    "event_type": {
      "type": "string",
      "enum": [
        "military_strike",
        "sanctions",
        "export_control",
        "shipping_disruption",
        "infrastructure_damage",
        "diplomatic_escalation",
        "commodity_supply_shock",
        "trade_policy_change"
      ],
      "description": "Category of geopolitical event"
    },
    "source": {
      "type": "object",
      "description": "Information about the event source",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "official_government",
            "wire_service",
            "financial_data_provider",
            "industry_analyst",
            "expert_commentary",
            "social_media",
            "other"
          ]
        },
        "tier": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "published_at": {
          "type": "string",
          "format": "date-time"
        },
        "headline": {
          "type": "string",
          "maxLength": 500
        }
      }
    },
    "contradiction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "description"],
      "properties": {
        "field": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "description": {
          "type": "string",
          "minLength": 5,
          "maxLength": 1000
        },
        "source_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "uniqueItems": true
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence level from 0.0 to 1.0"
    },
    "raw_input": {
      "type": "object",
      "description": "Original input data",
      "properties": {
        "text": { "type": "string" },
        "links": {
          "type": "array",
          "items": { "type": "string", "format": "uri" }
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata",
      "properties": {
        "discovery_mode": { "type": "boolean" },
        "escalation_score": { "type": "number", "minimum": 0, "maximum": 10 },
        "fog_of_war": { "type": "boolean" }
      }
    }
  }
}
