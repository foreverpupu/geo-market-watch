{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://geo-market-watch/schemas/watchlist-item.json",
  "title": "Geo Market Watch Watchlist Item",
  "description": "Structured watchlist item generated from geopolitical-to-market mapping.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "watchlist_id",
    "event_id",
    "asset_name",
    "asset_type",
    "market",
    "direction_bias",
    "thesis",
    "physical_mapping_node",
    "trigger_signal",
    "invalidation_condition",
    "confidence_level",
    "time_horizon",
    "status"
  ],
  "properties": {
    "watchlist_id": {
      "type": "string",
      "pattern": "^wl-[0-9]{4}-[0-9]{4,}$",
      "description": "Unique watchlist item identifier."
    },
    "event_id": {
      "type": "string",
      "pattern": "^gmw-[0-9]{4}-[0-9]{4,}$",
      "description": "Reference to the originating event."
    },
    "ticker": {
      "type": "string",
      "minLength": 1,
      "maxLength": 30,
      "description": "Tradable ticker or symbol when applicable."
    },
    "asset_name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 200,
      "description": "Human-readable asset or instrument name."
    },
    "asset_type": {
      "type": "string",
      "enum": [
        "stock",
        "etf",
        "index",
        "commodity",
        "currency",
        "bond",
        "sector",
        "basket",
        "other"
      ]
    },
    "market": {
      "type": "string",
      "enum": [
        "US",
        "CN",
        "HK",
        "EU",
        "JP",
        "KR",
        "TW",
        "IN",
        "GLOBAL",
        "OTHER"
      ]
    },
    "exchange": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50
    },
    "direction_bias": {
      "type": "string",
      "enum": [
        "bullish",
        "bearish",
        "two_way",
        "monitor_only"
      ],
      "description": "Directional bias implied by the thesis."
    },
    "thesis": {
      "type": "string",
      "minLength": 20,
      "maxLength": 3000,
      "description": "Why this asset belongs on the watchlist."
    },
    "physical_mapping_node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_name",
        "node_type",
        "mapping_logic"
      ],
      "properties": {
        "node_name": {
          "type": "string",
          "minLength": 2,
          "maxLength": 200
        },
        "node_type": {
          "type": "string",
          "enum": [
            "shipping_lane",
            "port",
            "pipeline",
            "mine",
            "refinery",
            "commodity_flow",
            "supply_chain_stage",
            "policy_node",
            "substitution_path",
            "other"
          ]
        },
        "mapping_logic": {
          "type": "string",
          "minLength": 10,
          "maxLength": 1500
        }
      }
    },
    "trigger_signal": {
      "type": "array",
      "description": "Observable conditions that strengthen or confirm the thesis.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/triggerSignal"
      }
    },
    "invalidation_condition": {
      "type": "array",
      "description": "Conditions under which the thesis weakens or should be removed.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/invalidationCondition"
      }
    },
    "supporting_indicators": {
      "type": "array",
      "description": "Optional quantitative or qualitative indicators relevant to tracking the thesis.",
      "items": {
        "$ref": "#/$defs/indicator"
      }
    },
    "confidence_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "time_horizon": {
      "type": "string",
      "enum": [
        "intraday",
        "days",
        "weeks",
        "months",
        "multi_quarter"
      ]
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "triggered",
        "invalidated",
        "resolved",
        "archived"
      ]
    },
    "scenario_dependency": {
      "type": "string",
      "minLength": 5,
      "maxLength": 1000,
      "description": "Optional note describing which scenario this item depends on."
    }
  },
  "$defs": {
    "triggerSignal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal_id",
        "description",
        "signal_category",
        "observable"
      ],
      "properties": {
        "signal_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "description": {
          "type": "string",
          "minLength": 10,
          "maxLength": 1000
        },
        "signal_category": {
          "type": "string",
          "enum": [
            "price_action",
            "volume",
            "policy",
            "logistics",
            "production",
            "inventory",
            "official_statement",
            "geopolitical",
            "macro",
            "other"
          ]
        },
        "observable": {
          "type": "boolean"
        },
        "threshold": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "time_window": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        }
      }
    },
    "invalidationCondition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "condition_id",
        "description",
        "severity"
      ],
      "properties": {
        "condition_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "description": {
          "type": "string",
          "minLength": 10,
          "maxLength": 1000
        },
        "severity": {
          "type": "string",
          "enum": [
            "partial",
            "full"
          ]
        },
        "time_window": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        }
      }
    },
    "indicator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "indicator_name",
        "indicator_type"
      ],
      "properties": {
        "indicator_name": {
          "type": "string",
          "minLength": 2,
          "maxLength": 200
        },
        "indicator_type": {
          "type": "string",
          "enum": [
            "price",
            "volume",
            "spread",
            "freight",
            "inventory",
            "production",
            "policy",
            "sentiment",
            "other"
          ]
        },
        "unit": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50
        },
        "source": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        }
      }
    }
  }
}
